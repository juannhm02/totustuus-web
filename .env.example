# Puerto único de la aplicación
PORT=8787

# Origen público de la web
CLIENT_ORIGIN=http://localhost:8787

# Base de la API usada por el frontend
VITE_API_BASE=/api

# Correo donde quieres recibir los pedidos
ADMIN_EMAIL=tu-correo@dominio.com

# Acceso al panel de administración en /admin
ADMIN_BASIC_USER=admin
ADMIN_BASIC_PASS=cambia-esta-clave-larga-y-segura

# Configuración SMTP
# Ejemplo Gmail:
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=tu-correo@gmail.com
# SMTP_PASS=tu-contrasena-de-aplicacion
# SMTP_FROM=ToTusTuus <tu-correo@gmail.com>

SMTP_HOST=smtp.tu-proveedor.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=tu-correo@dominio.com
SMTP_PASS=tu-clave-smtp
SMTP_FROM=ToTusTuus <tu-correo@dominio.com>
